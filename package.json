{
  "name": "stakd",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm-run-all --parallel dev:build dev:serve",
    "dev:build": "esbuild \"app.jsx\" --bundle --format=esm --sourcemap --outfile=\"dist/app.js\" --watch",
    "dev:serve": "serve . -p 8000 -s",
    "build": "esbuild \"app.jsx\" --bundle --format=esm --minify --outfile=\"dist/app.js\"",
    "lint": "eslint . --ext .js,.jsx",
    "format": "prettier --write \"**/*.{js,jsx,json,css,md}\"",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.0",
    "serve": "^14.2.4"
  }
}
